# FastAPI base URL (no trailing slash). Local default: http://localhost:8000
# On Vercel (Services), leave unset in production to use same-origin /_/backend unless you change vercel.json.
VITE_API_URL=http://localhost:8000

# Optional: API path prefix on same origin (default /_/backend). Only used when VITE_API_URL is unset and build is production.
# VITE_VERCEL_API_PREFIX=/_/backend

# Optional: Supabase JWT for /graphs/* (or set localStorage tot_access_token, or use Supabase Auth in-app)
# VITE_ACCESS_TOKEN=

# Optional: load this graph id on /graph when no ?graph= query
# VITE_GRAPH_ID=
