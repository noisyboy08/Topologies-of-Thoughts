# FastAPI base URL (no trailing slash). Defaults to http://localhost:8000
VITE_API_URL=http://localhost:8000

# Optional: Supabase JWT for /graphs/* (or set localStorage tot_access_token, or use Supabase Auth in-app)
# VITE_ACCESS_TOKEN=

# Optional: load this graph id on /graph when no ?graph= query
# VITE_GRAPH_ID=
